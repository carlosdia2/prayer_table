FROM node:22-alpine AS builder

WORKDIR /app

RUN corepack enable

ARG VITE_API_BASE_URL
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.json tsconfig.base.json ./
COPY artifacts/api-server/package.json artifacts/api-server/package.json
COPY artifacts/mesa-de-oracion/package.json artifacts/mesa-de-oracion/package.json
COPY lib/api-client-react/package.json lib/api-client-react/package.json
COPY lib/api-spec/package.json lib/api-spec/package.json
COPY lib/api-zod/package.json lib/api-zod/package.json
COPY lib/db/package.json lib/db/package.json
COPY scripts/package.json scripts/package.json

RUN pnpm install --frozen-lockfile

COPY . .

RUN pnpm --filter @workspace/mesa-de-oracion run build

FROM nginx:1.27-alpine AS web

COPY deploy/nginx-web.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/artifacts/mesa-de-oracion/dist/public /usr/share/nginx/html

EXPOSE 80
