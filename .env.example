# Frontend build-time env
VITE_API_BASE_URL=https://api.tu-dominio.com

# API runtime env
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
SESSION_SECRET=change-me-with-a-long-random-secret
CORS_ORIGIN=https://tu-dominio.com
WEB_PUBLIC_URL=https://tu-dominio.com
API_PUBLIC_URL=https://api.tu-dominio.com

# Google OAuth, optional until login is configured
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Usually keep lax when web and api share the same root domain.
# Use none only if cookies must work cross-site, and only over HTTPS.
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=
